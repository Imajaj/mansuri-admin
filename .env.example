# ==============================================================
# .env.example
# ==============================================================
# COPY this file to backend/.env and fill in your real values.
# NEVER commit the actual .env file to GitHub.
# The .gitignore file below ensures this.
#
# For Railway production deployment, you set these as
# "Environment Variables" in the Railway dashboard — NOT in a file.
# ==============================================================

# ── Database ──────────────────────────────────────────────────
# Get this from Supabase: Settings → Database → Connection String → URI
# It looks like: postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# ── Security ──────────────────────────────────────────────────
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then paste the result here.
SECRET_KEY=replace-this-with-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── First Admin User ──────────────────────────────────────────
# These are used to create the first admin account automatically.
# CHANGE THESE before going live!
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin123
FIRST_ADMIN_EMAIL=admin@yourdomain.com
